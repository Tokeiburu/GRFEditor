<UserControl x:Class="GRFEditor.Tools.SpriteEditor.SpriteEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GRFEditor.Tools.SpriteEditor"
			 xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
             mc:Ignorable="d" Foreground="{DynamicResource TextForeground}"
             d:DesignHeight="450" d:DesignWidth="800" KeyUp="_keyUp">
	<UserControl.Resources>
		<Style TargetType="{x:Type ListViewItem}">
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		</Style>
		<Style TargetType="{x:Type ListView}">
			<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
		</Style>
	</UserControl.Resources>
	<Grid AllowDrop="False" Background="{DynamicResource TabItemBackground}">
		<Grid.RowDefinitions>
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
			<RowDefinition />
			<RowDefinition Height="auto" />
		</Grid.RowDefinitions>
		<Grid Name="_gridLists" Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="300" />
				<ColumnDefinition Width="300" />
				<ColumnDefinition />
			</Grid.ColumnDefinitions>
			<Grid Grid.Column="0">
				<Grid.RowDefinitions>
					<RowDefinition Height="auto" />
					<RowDefinition />
				</Grid.RowDefinitions>
				<TextBlock Text="Indexed8" Margin="3" Grid.Row="0" />
				<ListView Background="{DynamicResource TabItemBackground}" Foreground="{DynamicResource TextForeground}" Drop="_imSprList1_Drop" SelectionMode="Extended" ScrollViewer.HorizontalScrollBarVisibility="Hidden" Grid.Row="1" Name="_imSprList1" MinHeight="125" Margin="3 0 3 3" SelectionChanged="_imSprList1_SelectionChanged" PreviewMouseLeftButtonDown="_imSprList_PreviewMouseLeftButtonDown" AllowDrop="True">
					<ListView.ContextMenu>
						<ContextMenu Name="_imSprList1ContextMenu">
							<MenuItem Name="_menuDelete1" Header="Delete" TokeiLibrary:WpfProperties.ImagePath="delete.png" Click="_menuDelete1_Click" />
							<MenuItem Name="_menuInsertBefore1" Header="Insert before" TokeiLibrary:WpfProperties.ImagePath="add.png" Click="_menuInsertBefore1_Click" />
							<MenuItem Name="_menuInsertAfter1" Header="Insert after" TokeiLibrary:WpfProperties.ImagePath="add.png" Click="_menuInsertAfter1_Click" />
							<MenuItem Name="_menuReplace1" Header="Replace with..." TokeiLibrary:WpfProperties.ImagePath="refresh.png" Click="_menuReplace1_Click" />
							<MenuItem Name="_menuChangeId1" Header="Set ID..." TokeiLibrary:WpfProperties.ImagePath="hash.png" Click="_menuChangeId1_Click" />
							<Separator />
							<MenuItem Name="_menuExtract1" Header="Extract..." TokeiLibrary:WpfProperties.ImagePath="export.png" Click="_menuExtract1_Click" />
							<MenuItem Name="_menuToBgra32" Header="Convert to Bgra32" TokeiLibrary:WpfProperties.ImagePath="export.png" Click="_menuToBgra32_Click" />
							<Separator />
							<MenuItem Header="Transform">
								<MenuItem Name="_menuToFlipVert1" Header="Flip vertically" TokeiLibrary:WpfProperties.ImagePath="flip.png" Click="_menuToFlipVert1_Click" />
								<MenuItem Name="_menuToFlipHoriz1" Header="Flip horizontally" TokeiLibrary:WpfProperties.ImagePath="flip2.png" Click="_menuToFlipHoriz1_Click" />
							</MenuItem>
						</ContextMenu>
					</ListView.ContextMenu>
				</ListView>
			</Grid>
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="auto" />
					<RowDefinition />
				</Grid.RowDefinitions>
				<TextBlock Text="Bgra32" Margin="3" Grid.Row="0" />
				<ListView  Background="{DynamicResource TabItemBackground}" Foreground="{DynamicResource TextForeground}" Drop="_imSprList2_Drop" AllowDrop="True" SelectionMode="Extended" Grid.Row="1" ScrollViewer.HorizontalScrollBarVisibility="Hidden" Name="_imSprList2" MinHeight="125" Margin="3 0 3 3" SelectionChanged="_imSprList2_SelectionChanged" PreviewMouseLeftButtonDown="_imSprList_PreviewMouseLeftButtonDown">
					<ListView.ContextMenu>
						<ContextMenu Name="_imSprList2ContextMenu">
							<MenuItem Name="_menuDelete2" Header="Delete" TokeiLibrary:WpfProperties.ImagePath="delete.png" Click="_menuDelete2_Click" />
							<MenuItem Name="_menuInsertBefore2" Header="Insert before" TokeiLibrary:WpfProperties.ImagePath="add.png" Click="_menuInsertBefore2_Click" />
							<MenuItem Name="_menuInsertAfter2" Header="Insert after" TokeiLibrary:WpfProperties.ImagePath="add.png" Click="_menuInsertAfter2_Click" />
							<MenuItem Name="_menuReplace2" Header="Replace with..." TokeiLibrary:WpfProperties.ImagePath="refresh.png" Click="_menuReplace2_Click" />
							<MenuItem Name="_menuChangeId2" Header="Set ID..." TokeiLibrary:WpfProperties.ImagePath="hash.png" Click="_menuChangeId2_Click" />
							<Separator />
							<MenuItem Name="_menuExtract2" Header="Extract..." TokeiLibrary:WpfProperties.ImagePath="export.png" Click="_menuExtract2_Click" />
							<MenuItem Name="_menuToIndexed8" Header="Convert to Indexed8" TokeiLibrary:WpfProperties.ImagePath="export.png" Click="_menuToIndexed8_Click" />
							<Separator />
							<MenuItem Header="Transform">
								<MenuItem Name="_menuToFlipVert2" Header="Flip horizontally" TokeiLibrary:WpfProperties.ImagePath="flip.png" Click="_menuToFlipVert2_Click" />
								<MenuItem Name="_menuToFlipHoriz2" Header="Flip vertically" TokeiLibrary:WpfProperties.ImagePath="flip2.png" Click="_menuToFlipHoriz2_Click" />
							</MenuItem>
						</ContextMenu>
					</ListView.ContextMenu>
				</ListView>
			</Grid>
			<Grid Grid.Column="2">
				<Grid.RowDefinitions>
					<RowDefinition Height="auto" />
					<RowDefinition />
				</Grid.RowDefinitions>
				<TextBlock Grid.Row="0" Name="_imSprInfo" Margin="3" />
				<ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" RenderOptions.BitmapScalingMode="NearestNeighbor">
					<ScrollViewer.Background>
						<ImageBrush ImageSource="/Resources/background.png" TileMode="Tile" Stretch="None" Viewport="0,0,16,16" ViewportUnits="Absolute" />
					</ScrollViewer.Background>
					<Image Name="_imSprImage" Margin="3" RenderOptions.BitmapScalingMode="NearestNeighbor" HorizontalAlignment="Left" VerticalAlignment="Top" SnapsToDevicePixels="True" Stretch="None" RenderTransformOrigin="0.5,0.5" />
				</ScrollViewer>
			</Grid>
		</Grid>
	</Grid>
</UserControl>
