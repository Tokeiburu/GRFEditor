<Styles:TkWindow x:Class="GRFEditor.Tools.SpriteEditor.SpriteConverter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" AllowDrop="False"
                 xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
                 xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
                 xmlns:SpriteEditorConfiguration="clr-namespace:GRFEditor.Tools.SpriteEditor"
                 xmlns:ListView="clr-namespace:TokeiLibrary.WPF.Styles.ListView;assembly=TokeiLibrary"
				 ShowInTaskbar="True" SnapsToDevicePixels="True" UseLayoutRounding="True"
				 Background="{DynamicResource TabItemBackground}" Foreground="{DynamicResource TextForeground}">
    <Grid AllowDrop="True" DragEnter="_presenter_DragEnter" Drop="_presenter_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Menu Margin="0 0 0 0" Height="30">
            <MenuItem VerticalAlignment="Center">
                <MenuItem.Header>
                    <Label Content="File" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-5 0 -5 0" />
                </MenuItem.Header>
				<MenuItem Click="_menuItemNew_Click" TokeiLibrary:WpfProperties.ImagePath="add.png" Name="_menuItemNew" Header="New" />
				<MenuItem Click="_menuItemOpen_Click" TokeiLibrary:WpfProperties.ImagePath="newFile.png" Name="_menuItemOpen" Header="Open" />
				<MenuItem IsEnabled="False" TokeiLibrary:WpfProperties.ImagePath="empty.png" Name="_menuItemRecent" Header="Open recent" />
				<Separator />
				<MenuItem Click="_menuItemCloseSprite_Click" TokeiLibrary:WpfProperties.ImagePath="empty.png" Name="_menuItemCloseSprite" Header="Close sprite" />
				<Separator />
				<MenuItem Click="_menuItemSave_Click" TokeiLibrary:WpfProperties.ImagePath="save.png" Name="_menuItemSave" Header="Save" />
				<MenuItem Click="_menuItemSaveAs_Click" TokeiLibrary:WpfProperties.ImagePath="empty.png" Name="_menuItemSaveAs" Header="Save as..." />
				<MenuItem Click="_menuItemExportAll_Click" TokeiLibrary:WpfProperties.ImagePath="empty.png" Name="_menuItemExportAll" Header="Export all..." />
				<MenuItem Click="_menuItemClose_Click" TokeiLibrary:WpfProperties.ImagePath="empty.png" Name="_menuItemClose" Header="Close" />
			</MenuItem>
            <MenuItem VerticalAlignment="Center">
                <MenuItem.Header>
                    <Label Content="Options" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-5 0 -5 0" />
                </MenuItem.Header>
                <MenuItem Name="_menuItem" Header="Palette">
					<MenuItem Name="_menuItemPalView" Click="_menuItemPalView_Click" Header="View" />
					<MenuItem Name="_menuItemPalReplaceWith" Click="_menuItemPalReplaceWith_Click" Header="Replace with..." />
					<MenuItem Name="_menuItemPalReplaceDefault" Click="_menuItemPalReplaceDefault_Click" Header="Replace with default" />
					<MenuItem Name="_menuItemPalClear" Click="_menuItemPalClear_Click" Header="Clear" />
				</MenuItem>
				<MenuItem Foreground="{DynamicResource TextForeground}" Name="_cbUseTga" Header="Export as TGA (instead of PNG)" IsCheckable="True" Margin="3" IsChecked="{Binding Path=(SpriteEditorConfiguration:SpriteEditorConfiguration.UseTgaImages), Mode=TwoWay}" />
            </MenuItem>
            <MenuItem>
                <MenuItem.Header>
                    <Label Content="Help" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="-5 0 -5 0" />
                </MenuItem.Header>
				<MenuItem Name="_menuItemAbout" TokeiLibrary:WpfProperties.ImagePath="help.png" Click="_menuItemAbout_Click" Header="About..." />
			</MenuItem>
        </Menu>
		<TabControl Background="{DynamicResource TabItemBackground}" Name="_mainTabControl" Grid.Row="1" Style="{DynamicResource TabControlSprite}" />
	</Grid>
</Styles:TkWindow>