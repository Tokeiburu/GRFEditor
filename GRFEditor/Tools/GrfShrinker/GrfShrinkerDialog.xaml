<Styles:TkWindow x:Class="GRFEditor.Tools.GrfShrinker.GrfShrinkerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
		xmlns:ApplicationConfiguration="clr-namespace:GRFEditor.ApplicationConfiguration"
		xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
        xmlns:ListView="clr-namespace:TokeiLibrary.WPF.Styles.ListView;assembly=TokeiLibrary"
        xmlns:MultiGrf="clr-namespace:GrfToWpfBridge.MultiGrf;assembly=GrfToWpfBridge"
		MinHeight="400" Height="400" Width="750" MinWidth="750">
	<Grid>
		<Grid.Resources>
			<Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource ThemeCheckBoxStyle}">
				<Setter Property="Foreground" Value="{DynamicResource TextForeground}" />
				<Setter Property="Margin" Value="3" />
				<Setter Property="VerticalAlignment" Value="Center" />
				<Setter Property="HorizontalAlignment" Value="Left" />
				<Setter Property="ToolTipService.ShowDuration" Value="30000" />

				<Setter Property="ContentTemplate">
					<Setter.Value>
						<DataTemplate>
							<TextBlock Text="{Binding}" x:Name="text"/>
							<DataTemplate.Triggers>
								<DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=CheckBox}}" Value="True">
									<Setter TargetName="text" Property="TextDecorations" Value="Underline"/>
								</DataTrigger>
							</DataTemplate.Triggers>
						</DataTemplate>
					</Setter.Value>
				</Setter>

				<Style.Triggers>
					<Trigger Property="IsMouseOver" Value="True">
						<Setter Property="Cursor" Value="Hand"/>
						<Setter Property="Foreground" Value="{DynamicResource MouseOverTextBrush}" />
					</Trigger>
				</Style.Triggers>
			</Style>
		</Grid.Resources>
		<Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Border Background="{DynamicResource TabControlBackground}">
            <TabControl Name="_tabControl" Style="{DynamicResource TabControlStyled}">
				<TabItem Header="Shrink options" Style="{DynamicResource TabItemStyled}" Foreground="{StaticResource TextForeground}">
					<StackPanel>
						<StackPanel>
							<Label Content="{Binding Path=Header, RelativeSource={RelativeSource AncestorType={x:Type TabItem}}, FallbackValue='Shrink options'}" FontWeight="Bold" FontSize="16" Margin="3 10 0 5" />
							<Rectangle Margin="5 0 5 5" Stroke="{DynamicResource SeperatorBrush}" VerticalAlignment="Stretch" />
						</StackPanel>
						<TextBlock Text="Errors to look for :" Margin="3" />
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="auto" />
								<ColumnDefinition Width="auto" />
							</Grid.ColumnDefinitions>
							<StackPanel>
								<CheckBox Name="_cbRemoveUnusedSpriteImages" Content="Removed unused images in SPR files" IsChecked="{Binding Path=(ApplicationConfiguration:GrfEditorConfiguration.SH_RemoveUnusedSpriteImages), Mode=TwoWay}" />
								<CheckBox Name="_cbDowngradeTextures" Content="Convert Bgr24 textures in Indexed8 textures (small quality loss)" IsChecked="{Binding Path=(ApplicationConfiguration:GrfEditorConfiguration.SH_DowngradeTextures), Mode=TwoWay}" />
								<CheckBox Name="_cbUseLzmaCompression" Content="Use LZMA compression (requires custom DLL for client)" IsChecked="{Binding Path=(ApplicationConfiguration:GrfEditorConfiguration.SH_UseLzmaCompression), Mode=TwoWay}" />
								<CheckBox Name="_cbRedirect" Content="Redirect identical GRF entries (Save > Redirect indexes)" IsChecked="{Binding Path=(ApplicationConfiguration:GrfEditorConfiguration.SH_Redirect), Mode=TwoWay}" />
							</StackPanel>
						</Grid>
					</StackPanel>
				</TabItem>
			</TabControl>
        </Border>
        <Grid TokeiLibrary:WpfProperties.IsDraggable="True" Grid.Row="1" Height="40" Background="{DynamicResource UIDialogBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Styles:TkProgressBar x:Name="_progressBar" Margin="3 0 0 0" />
                <DockPanel HorizontalAlignment="Right" Grid.Column="1" Margin="0 0 3 0">
                    <Button Name="_buttonStart" Content="Shrink" Height="24" Width="100" Click="_buttonStart_Click" Margin="3" />
                    <Button Name="_buttonCancel" Content="Close" Height="24" Width="100" Click="_buttonCancel_Click" Margin="3" />
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</Styles:TkWindow>
