<UserControl x:Class="GRFEditor.WPF.PreviewTabs.Controls.PreviewActIndexSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
             xmlns:local="clr-namespace:GRFEditor.WPF.PreviewTabs.Controls" xmlns:actselectorcomponents="clr-namespace:GrfToWpfBridge.ActRenderer.ActSelectorComponents;assembly=GrfToWpfBridge" xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary" xmlns:WPF="clr-namespace:GRFEditor.WPF"
			 mc:Ignorable="d">
	<WrapPanel>
		<actselectorcomponents:ActionDirectionalControl x:Name="_directionalControl" VerticalAlignment="Bottom" ButtonSize="20" />
		<Grid HorizontalAlignment="Left">
			<Grid.RowDefinitions>
				<RowDefinition />
				<RowDefinition Height="auto" />
			</Grid.RowDefinitions>
			<StackPanel>
				<Styles:FancyButton x:Name="_buttonScale" TokeiLibrary:WpfProperties.ImagePath="scale.png" HorizontalAlignment="Left" VerticalAlignment="Top" Width="20" Height="20" ToolTip="Change the rendering mode of the animation." />
				<Styles:FancyButton x:Name="_buttonExportAsGif" TokeiLibrary:WpfProperties.ImagePath="file_gif.png" Grid.Row="0" Grid.Column="0" Height="20" Width="20" HorizontalAlignment="Left" VerticalAlignment="Top" ToolTip="Save animation as a gif image." />
				<WPF:QuickColorSelector ResizeBackground="True" Margin="2" Height="16" Width="16" x:Name="_qcsBackground" ColorBrush="{Binding Editor.Canvas.Background, RelativeSource={RelativeSource AncestorType=UserControl}}" HorizontalAlignment="Left" />
			</StackPanel>
		</Grid>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition />
				<RowDefinition />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="auto" />
				<ColumnDefinition />
			</Grid.ColumnDefinitions>
			<TextBlock Text="Animation" VerticalAlignment="Center" TextAlignment="Center" Margin="3 3 3 0" TextWrapping="Wrap" />
			<TextBlock Text="Action" Grid.Row="1" VerticalAlignment="Center" Margin="3" TextAlignment="Center" TextWrapping="Wrap" />
			<ComboBox Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Name="_comboBoxAnimationIndex" Height="22" Width="80" HorizontalAlignment="Left" Margin="3" />
			<ComboBox Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"  Name="_comboBoxActionIndex" Height="22" Width="80" HorizontalAlignment="Left" Margin="3" />
		</Grid>
	</WrapPanel>
</UserControl>
